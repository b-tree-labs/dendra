{
  "name": "postrule",
  "displayName": "Postrule",
  "description": "Inline diagnostics for Postrule analyzer hazards, plus an auto-lift quick-fix.",
  "version": "1.1.0",
  "publisher": "b-tree-labs",
  "license": "Apache-2.0",
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Linters",
    "Other"
  ],
  "main": "./out/extension.js",
  "activationEvents": [
    "onLanguage:python"
  ],
  "contributes": {
    "configuration": {
      "title": "Postrule",
      "properties": {
        "postrule.binaryPath": {
          "type": "string",
          "default": "postrule",
          "description": "Path to the postrule CLI. Leave as 'postrule' to resolve from PATH."
        },
        "postrule.enable": {
          "type": "boolean",
          "default": true,
          "description": "Enable Postrule diagnostics for Python files."
        }
      }
    },
    "commands": [
      {
        "command": "postrule.rescanWorkspace",
        "title": "Postrule: Re-scan workspace"
      },
      {
        "command": "postrule.aiAutoLift",
        "title": "Postrule: run auto-lift here"
      }
    ]
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "pretest": "npm run compile",
    "test": "node ./out/test/runTest.js"
  },
  "devDependencies": {
    "@types/glob": "^8.1.0",
    "@types/mocha": "^10.0.6",
    "@types/node": "^20.11.0",
    "@types/vscode": "^1.85.0",
    "@vscode/test-electron": "^2.3.9",
    "glob": "^13.0.6",
    "mocha": "^11.7.5",
    "typescript": "^5.3.3",
    "@vscode/vsce": "^3.9.1"
  },
  "overrides": {
    "serialize-javascript": "^7.0.5",
    "diff": "^9.0.0"
  }
}
