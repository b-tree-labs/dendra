# =====================================================================
# Dendra dashboard — environment variable contract
#
# Copy this file to `.env.local` and fill in real values for local dev:
#   cp cloud/dashboard/.env.example cloud/dashboard/.env.local
#
# For production, paste the same names + values into:
#   Cloudflare Pages → dashboard project → Settings → Environment variables
# =====================================================================

# --- Clerk (auth) ---------------------------------------------------
# Free tier, ~10k MAU. Create an app at https://clerk.com.
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_REPLACE_ME
CLERK_SECRET_KEY=sk_test_REPLACE_ME

# Where Clerk routes after sign-in / sign-up. Defaults are fine for dev.
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/dashboard
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/dashboard

# Public-facing dashboard origin used in CLI redirect URLs.
NEXT_PUBLIC_DASHBOARD_URL=http://localhost:3000

# --- Dendra api Worker connectivity --------------------------------
# The dashboard's /api/keys + /api/billing routes call the api Worker's
# /admin/* surface server-side, signed with the service token.
DENDRA_API_BASE_URL=https://staging-api.dendra.run
DENDRA_API_SERVICE_TOKEN=  # same value as the Worker's DASHBOARD_SERVICE_TOKEN secret

# --- Stripe ----------------------------------------------------------
# Test mode (sk_test_…) for local dev + staging; live mode (sk_live_…)
# only on the production Pages env. Never commit real values.
STRIPE_SECRET_KEY=sk_test_REPLACE_ME

# Output of `npx tsx scripts/sync-stripe-products.ts` (run from cloud/api/).
# Re-run the sync if you switch between test and live mode — the IDs
# differ across modes.
STRIPE_PRICE_ID_HOSTED_PRO=price_REPLACE_ME
STRIPE_PRICE_ID_HOSTED_SCALE=price_REPLACE_ME
STRIPE_PRICE_ID_HOSTED_BUSINESS=price_REPLACE_ME
