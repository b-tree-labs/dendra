# Clerk auth (free tier, ~10k MAU). Create an app at https://clerk.com,
# then copy the keys here. Never commit real values.
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_REPLACE_ME
CLERK_SECRET_KEY=sk_test_REPLACE_ME

# Where Clerk routes after sign-in / sign-up. Defaults are fine for dev.
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/dashboard
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/dashboard

# Supabase Postgres (cli_sessions table for the device-flow exchange,
# api_keys table once we issue keys server-side).
DATABASE_URL=postgres://user:pass@host:5432/dendra  # pragma: allowlist secret

# Public-facing dashboard origin used in CLI redirect URLs.
NEXT_PUBLIC_DASHBOARD_URL=http://localhost:3000
