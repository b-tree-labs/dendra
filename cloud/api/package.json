{
  "name": "postrule-api",
  "version": "1.0.0-rc1",
  "private": true,
  "description": "Postrule hosted API — Cloudflare Worker for /v1/verdicts, /v1/switches, /v1/judge with Bearer-token auth + tier enforcement.",
  "license": "BSL-1.1",
  "scripts": {
    "deploy:staging": "wrangler deploy",
    "deploy:production": "wrangler deploy --env production",
    "tail:staging": "wrangler tail",
    "tail:production": "wrangler tail --env production",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "hono": "^4.12.18",
    "stripe": "^22.1.0"
  },
  "devDependencies": {
    "@cloudflare/vitest-pool-workers": "^0.15.2",
    "@cloudflare/workers-types": "^4.20260101.0",
    "typescript": "^5.7.0",
    "vitest": "^4.1.0",
    "wrangler": "^4.87.0"
  },
  "overrides": {
    "undici": "^6.23.1"
  }
}
