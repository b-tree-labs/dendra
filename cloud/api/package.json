{
  "name": "dendra-api",
  "version": "1.0.0-rc1",
  "private": true,
  "description": "Dendra hosted API — Cloudflare Worker for /v1/verdicts, /v1/switches, /v1/judge with Bearer-token auth + tier enforcement.",
  "license": "BSL-1.1",
  "scripts": {
    "deploy:staging": "wrangler deploy",
    "deploy:production": "wrangler deploy --env production",
