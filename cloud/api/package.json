    "tail:production": "wrangler tail --env production",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "hono": "^4.6.14"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20260101.0",
    "@cloudflare/vitest-pool-workers": "^0.5.40",
    "typescript": "^5.7.0",
    "vitest": "^2.1.8"
  }
}
