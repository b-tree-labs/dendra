{
  "name": "dendra",
  "displayName": "Dendra",
  "description": "Inline diagnostics for Dendra analyzer hazards, plus an auto-lift quick-fix.",
  "version": "1.1.0",
  "publisher": "axiom-labs-os",
  "license": "Apache-2.0",
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Linters",
    "Other"
  ],
  "main": "./out/extension.js",
  "activationEvents": [
    "onLanguage:python"
  ],
  "contributes": {
    "configuration": {
      "title": "Dendra",
      "properties": {
        "dendra.binaryPath": {
          "type": "string",
          "default": "dendra",
          "description": "Path to the dendra CLI. Leave as 'dendra' to resolve from PATH."
        },
        "dendra.enable": {
          "type": "boolean",
          "default": true,
          "description": "Enable Dendra diagnostics for Python files."
        }
      }
    },
    "commands": [
      {
        "command": "dendra.rescanWorkspace",
        "title": "Dendra: Re-scan workspace"
      },
      {
        "command": "dendra.runAutoLift",
        "title": "Dendra: run auto-lift here"
      }
    ]
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "pretest": "npm run compile",
    "test": "node ./out/test/runTest.js"
  },
  "devDependencies": {
    "@types/glob": "^8.1.0",
    "@types/mocha": "^10.0.6",
    "@types/node": "^20.11.0",
    "@types/vscode": "^1.85.0",
    "@vscode/test-electron": "^2.3.9",
    "glob": "^13.0.6",
    "mocha": "^10.3.0",
    "typescript": "^5.3.3",
    "vsce": "^2.15.0"
  }
}
